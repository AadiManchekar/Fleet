    {
      "id": "vv02NnCpEGLWeCb1gUX3F",
      "type": "text",
      "x": 40,
      "y": 633.5,
      "width": 673.007080078125,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 90,
      "groupIds": [],
